# =============================================================================
# .gitignore - Edge Blight Classifier (TFM UOC)
# =============================================================================
# Proyecto: Evaluacion comparativa CNN vs ViT en dispositivos Edge
# Filosofia: no versionar datos pesados, modelos entrenados ni outputs.
# SI versionar: codigo, configs, CSVs de metricas pequenios, figuras finales.
# =============================================================================


# =============================================================================
# DATASETS Y MODELOS PESADOS (NUNCA en git)
# =============================================================================

# Datasets de imagenes
dataset/
datasets/
data/
**/PlantVillage/
**/Plantville/
**/mendeley_uncontrolled_Environment/
**/Addis/
**/GerardoQuizhpe/
**/PropioVictor/

# Checkpoints entrenados (.pth de PyTorch)
*.pth
*.pt
*.ckpt
*.safetensors

# Modelos exportados (ONNX, TFLite, TensorRT)
*.onnx
*.tflite
*.engine
*.trt
*.pb
tf_saved_model/
tflite_output/

# Datos de calibracion INT8
calib_data.npy
*.npy
*.npz

# Cache de Hugging Face / timm
.cache/
~/.cache/huggingface/
hub/


# =============================================================================
# OUTPUTS DEL PIPELINE (regenerables, no versionar)
# =============================================================================

# Carpeta de outputs completa (regenerable con los scripts)
outputs/checkpoints/
outputs/exported/
outputs/logs/

# CSVs intermedios pesados
outputs/corpus/train.csv
outputs/corpus/val.csv
outputs/corpus/test.csv
outputs/corpus/duplicates*.csv
outputs/corpus/propio_inventory.csv

# Reportes de error analysis (pueden ser pesados con rutas completas)
outputs/metrics/error_analysis_misclassified.csv
outputs/metrics/diagnose_classification_reports.txt

# SI versionar (descomenta si los quieres):
# !outputs/corpus/corpus_summary.json   # metadatos pequenios
# !outputs/metrics/train_*.csv          # curvas de entrenamiento (KB)
# !outputs/metrics/edge_results_*.csv   # resultados Edge (KB)
# !outputs/figures/*.png                # figuras finales para memoria


# =============================================================================
# ARTEFACTOS TEMPORALES DE EDGE
# =============================================================================

# Pruebas y smoke tests
/tmp/smoke_*
smoke_*.onnx
test_*.onnx
*.tmp


# =============================================================================
